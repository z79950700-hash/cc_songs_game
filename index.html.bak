<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>你最爱的五月天 — 歌曲对决</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@400;700;900&family=Noto+Serif+SC:wght@400;600&display=swap" rel="stylesheet">
<style>
/* ===== RESET & BASE ===== */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --color-left: #e94560;
  --color-right: #0f3460;
  --font-sans: 'Noto Sans SC', sans-serif;
  --font-serif: 'Noto Serif SC', serif;
  --transition-speed: 0.35s;
}

html, body {
  width: 100%; height: 100%;
  overflow: hidden;
  background: #000;
  font-family: var(--font-sans);
  color: #fff;
  -webkit-font-smoothing: antialiased;
}

#app {
  width: 100vw;
  height: 100vh;
  position: relative;
  overflow: hidden;
}

/* ===== INTRO SCREEN ===== */
.intro-screen {
  width: 100%; height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  background: radial-gradient(ellipse at 50% 60%, #1a0a00 0%, #050510 60%);
  overflow: hidden;
}

.intro-particles {
  position: absolute;
  inset: 0;
  pointer-events: none;
}

.particle {
  position: absolute;
  border-radius: 50%;
  animation: floatUp linear infinite;
}

@keyframes floatUp {
  0%   { transform: translateY(100vh) translateX(0); opacity: 0; }
  10%  { opacity: 1; }
  90%  { opacity: 0.6; }
  100% { transform: translateY(-10vh) translateX(var(--drift, 20px)); opacity: 0; }
}

/* Band meta row */
.intro-meta {
  display: flex;
  align-items: center;
  gap: 0.6rem;
  font-size: 0.72rem;
  letter-spacing: 0.35em;
  color: rgba(255,255,255,0.3);
  text-transform: uppercase;
  margin-bottom: 2rem;
  animation: fadeInDown 1s ease 0.15s both;
}
.intro-meta-dot { color: rgba(255,150,50,0.4); }

/* Carrot mascot */
.intro-mascot {
  position: relative;
  margin-bottom: 1.8rem;
  animation: fadeInDown 1s ease 0.3s both;
}
.intro-mascot svg {
  display: block;
  animation: mascotFloat 3.5s ease-in-out infinite 1.2s;
  filter: drop-shadow(0 0 18px rgba(255,120,0,0.35));
}
.intro-mascot-glow {
  position: absolute;
  bottom: -6px;
  left: 50%;
  transform: translateX(-50%);
  width: 70px;
  height: 14px;
  background: radial-gradient(ellipse, rgba(255,120,0,0.3) 0%, transparent 70%);
  border-radius: 50%;
  animation: glowPulse 3.5s ease-in-out infinite 1.2s;
}
@keyframes mascotFloat {
  0%, 100% { transform: translateY(0) rotate(-1deg); }
  50%       { transform: translateY(-9px) rotate(1deg); }
}
@keyframes glowPulse {
  0%, 100% { opacity: 0.6; transform: translateX(-50%) scaleX(1); }
  50%       { opacity: 1;   transform: translateX(-50%) scaleX(1.15); }
}

/* Sparkle deco around mascot */
.intro-sparkle {
  position: absolute;
  animation: sparkleTwinkle ease-in-out infinite;
  color: #ffd060;
}
@keyframes sparkleTwinkle {
  0%, 100% { opacity: 0; transform: scale(0.4) rotate(0deg); }
  50%       { opacity: 1; transform: scale(1)   rotate(30deg); }
}

.intro-title {
  font-size: clamp(2.2rem, 7.5vw, 5.8rem);
  font-weight: 900;
  text-align: center;
  line-height: 1.15;
  margin-bottom: 1.1rem;
  animation: fadeInDown 1s ease 0.55s both;
  background: linear-gradient(155deg, #fff 35%, rgba(255,160,60,0.7) 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.intro-subtitle {
  font-size: clamp(0.85rem, 2.2vw, 1.05rem);
  color: rgba(255,255,255,0.45);
  margin-bottom: 3rem;
  font-family: var(--font-serif);
  text-align: center;
  line-height: 1.8;
  animation: fadeInDown 1s ease 0.8s both;
}

.intro-btn {
  padding: 0.95rem 2.8rem;
  font-size: 1rem;
  font-family: var(--font-sans);
  font-weight: 700;
  letter-spacing: 0.15em;
  background: transparent;
  border: 1.5px solid rgba(255,255,255,0.6);
  color: #fff;
  border-radius: 50px;
  cursor: pointer;
  position: relative;
  overflow: hidden;
  transition: all 0.3s ease;
  animation: fadeInUp 1s ease 1.05s both;
}
.intro-btn::before {
  content: '';
  position: absolute;
  inset: 0;
  background: rgba(255,130,30,0.12);
  transform: scaleX(0);
  transform-origin: left;
  transition: transform 0.3s ease;
}
.intro-btn:hover::before { transform: scaleX(1); }
.intro-btn:hover {
  border-color: rgba(255,200,100,0.8);
  box-shadow: 0 0 28px rgba(255,130,30,0.25), 0 0 60px rgba(255,130,30,0.1);
  transform: translateY(-2px);
}

.intro-rules {
  position: absolute;
  bottom: 2rem;
  font-size: 0.75rem;
  color: rgba(255,255,255,0.2);
  letter-spacing: 0.08em;
  animation: fadeInUp 1s ease 1.3s both;
  text-align: center;
}

@keyframes fadeInDown {
  from { opacity: 0; transform: translateY(-20px); }
  to   { opacity: 1; transform: translateY(0); }
}

@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(20px); }
  to   { opacity: 1; transform: translateY(0); }
}

/* ===== GAME SCREEN ===== */
.game-screen {
  width: 100%; height: 100%;
  position: relative;
  overflow: hidden;
  cursor: default;
}

/* Background layers — solid color, no image */
.bg-layer {
  position: absolute;
  inset: 0;
  transition: clip-path var(--transition-speed) cubic-bezier(.4,0,.2,1),
              opacity var(--transition-speed) ease;
  will-change: clip-path, opacity;
}

.bg-left  { clip-path: polygon(0 0, 50% 0, 50% 100%, 0 100%); }
.bg-right { clip-path: polygon(50% 0, 100% 0, 100% 100%, 50% 100%); }

/* Hover: expand chosen side, dim the other */
.game-screen.hover-left  .bg-left  { clip-path: polygon(0 0, 62% 0, 62% 100%, 0 100%); }
.game-screen.hover-left  .bg-right { clip-path: polygon(62% 0, 100% 0, 100% 100%, 62% 100%); opacity: 0.3; }
.game-screen.hover-right .bg-right { clip-path: polygon(38% 0, 100% 0, 100% 100%, 38% 100%); }
.game-screen.hover-right .bg-left  { clip-path: polygon(0 0, 38% 0, 38% 100%, 0 100%); opacity: 0.3; }

/* Center divider glow */
.seam {
  position: absolute;
  left: 50%;
  top: 0; bottom: 0;
  width: 1px;
  background: rgba(255,255,255,0.15);
  box-shadow: 0 0 20px 10px rgba(255,255,255,0.08);
  z-index: 5;
  pointer-events: none;
  transform: translateX(-50%);
  transition: left var(--transition-speed) cubic-bezier(.4,0,.2,1);
}

.game-screen.hover-left  .seam { left: 62%; }
.game-screen.hover-right .seam { left: 38%; }

/* Round counter */
.round-counter {
  position: absolute;
  top: 1.5rem;
  left: 50%;
  transform: translateX(-50%);
  z-index: 20;
  text-align: center;
  pointer-events: none;
}

.round-text {
  font-size: 0.75rem;
  letter-spacing: 0.3em;
  color: rgba(255,255,255,0.5);
  text-transform: uppercase;
}

.round-bar {
  margin-top: 0.4rem;
  width: 120px;
  height: 2px;
  background: rgba(255,255,255,0.15);
  border-radius: 2px;
  overflow: hidden;
}

.round-fill {
  height: 100%;
  background: rgba(255,255,255,0.7);
  border-radius: 2px;
  transition: width 0.4s ease;
}

/* "VS" badge */
.vs-badge {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  z-index: 20;
  width: 48px;
  height: 48px;
  border-radius: 50%;
  background: rgba(0,0,0,0.6);
  border: 1px solid rgba(255,255,255,0.2);
  backdrop-filter: blur(4px);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 0.7rem;
  font-weight: 700;
  letter-spacing: 0.05em;
  color: rgba(255,255,255,0.6);
  pointer-events: none;
  transition: opacity var(--transition-speed);
}

/* Song cards */
.cards-container {
  position: absolute;
  inset: 0;
  display: flex;
  z-index: 10;
}

.song-card {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 3rem 2rem;
  cursor: pointer;
  position: relative;
  transition: flex var(--transition-speed) cubic-bezier(.4,0,.2,1);
  user-select: none;
}

.game-screen.hover-left  .song-card.card-left  { flex: 1.24; }
.game-screen.hover-left  .song-card.card-right { flex: 0.76; }
.game-screen.hover-right .song-card.card-right { flex: 1.24; }
.game-screen.hover-right .song-card.card-left  { flex: 0.76; }

.card-inner {
  background: rgba(0,0,0,0.35);
  backdrop-filter: blur(3px) saturate(1.3);
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 16px;
  padding: 2rem 2.5rem;
  text-align: center;
  max-width: 340px;
  width: 100%;
  transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
}

.song-card:hover .card-inner {
  transform: translateY(-4px);
  box-shadow: 0 20px 60px rgba(0,0,0,0.4);
}

.card-left:hover .card-inner  { border-color: var(--color-left); box-shadow: 0 20px 60px rgba(0,0,0,0.4), 0 0 30px color-mix(in srgb, var(--color-left) 30%, transparent); }
.card-right:hover .card-inner { border-color: var(--color-right); box-shadow: 0 20px 60px rgba(0,0,0,0.4), 0 0 30px color-mix(in srgb, var(--color-right) 30%, transparent); }

.card-album-thumb {
  width: 220px;
  height: 220px;
  border-radius: 14px;
  object-fit: cover;
  margin: 0 auto 1.5rem;
  display: block;
  box-shadow: 0 16px 50px rgba(0,0,0,0.7);
  flex-shrink: 0;
  background: rgba(255,255,255,0.06);
}

.card-title {
  font-size: clamp(1.4rem, 3.5vw, 2.2rem);
  font-weight: 900;
  line-height: 1.2;
  margin-bottom: 0.5rem;
  color: #fff;
}

.card-album {
  font-size: 0.8rem;
  color: rgba(255,255,255,0.45);
  letter-spacing: 0.05em;
  margin-bottom: 1.8rem;
}

/* Award side panel (appears on hover, outside card-inner) */

.pick-btn {
  padding: 0.65rem 2rem;
  font-size: 0.9rem;
  font-family: var(--font-sans);
  font-weight: 700;
  letter-spacing: 0.1em;
  border: none;
  border-radius: 50px;
  cursor: pointer;
  transition: all 0.2s ease;
  position: relative;
  overflow: hidden;
}

.card-left .pick-btn {
  background: var(--color-left);
  color: #fff;
  box-shadow: 0 4px 20px color-mix(in srgb, var(--color-left) 50%, transparent);
}

.card-right .pick-btn {
  background: var(--color-right);
  color: #fff;
  box-shadow: 0 4px 20px color-mix(in srgb, var(--color-right) 50%, transparent);
}

.pick-btn:hover {
  transform: scale(1.05);
  filter: brightness(1.15);
}

.pick-btn:active {
  transform: scale(0.97);
}

/* Card animations */
@keyframes cardExit {
  to { opacity: 0; transform: translateY(30px) scale(0.95); }
}

@keyframes cardEnter {
  from { opacity: 0; transform: translateY(-30px) scale(0.95); }
  to   { opacity: 1; transform: translateY(0) scale(1); }
}

@keyframes cardWinPulse {
  0%   { transform: scale(1); }
  40%  { transform: scale(1.03); }
  100% { transform: scale(1); }
}

.card-exiting .card-inner  { animation: cardExit 0.25s ease forwards; }
.card-entering .card-inner { animation: cardEnter 0.35s ease forwards; }
.card-winning .card-inner  { animation: cardWinPulse 0.4s ease; }

/* ===== RESULT SCREEN ===== */
.result-screen {
  width: 100%; height: 100%;
  position: relative;
  overflow: hidden;  /* backgrounds live here, not in scroll layer */
}

.result-scroll {
  position: relative;
  z-index: 2;
  width: 100%; height: 100%;
  overflow-y: auto;
  overflow-x: hidden;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 4rem 1.5rem 6rem;
}

.result-bg {
  position: absolute;  /* absolute inside .result-screen, not fixed */
  inset: -10%;
  background-size: cover;
  background-position: center;
  filter: blur(22px) brightness(0.28) saturate(1.6);
  animation: kenBurns 30s ease-in-out infinite alternate;
  will-change: transform;
  z-index: 0;
}

@keyframes kenBurns {
  from { transform: scale(1.1) translate(0, 0); }
  to   { transform: scale(1.2) translate(-2%, -1.5%); }
}

.result-bg-overlay {
  position: absolute;  /* absolute inside .result-screen, not fixed */
  inset: 0;
  background: linear-gradient(to bottom, rgba(0,0,0,0.15) 0%, rgba(0,0,0,0.6) 100%);
  z-index: 1;
  pointer-events: none;
}

.result-content {
  position: relative;
  z-index: 2;
  text-align: center;
  max-width: 680px;
  width: 100%;
  animation: fadeInUp 0.8s ease both;
}

/* Extra result sections */
.result-section {
  position: relative;
  z-index: 2;
  max-width: 680px;
  width: 100%;
  margin-top: 3.5rem;
  animation: fadeInUp 0.8s ease both;
}

.result-section-title {
  font-size: 0.7rem;
  letter-spacing: 0.35em;
  color: rgba(255,255,255,0.35);
  text-transform: uppercase;
  margin-bottom: 1.2rem;
  text-align: center;
}

.result-section-divider {
  width: 100%;
  height: 1px;
  background: rgba(255,255,255,0.08);
  margin: 3rem 0 0;
}

/* Defeated chips */
.defeated-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
  justify-content: center;
}

.defeated-chip {
  padding: 0.35rem 0.9rem;
  border-radius: 50px;
  border: 1px solid rgba(255,255,255,0.12);
  font-size: 0.78rem;
  color: rgba(255,255,255,0.55);
  background: rgba(255,255,255,0.05);
}

.result-awards-list {
  display: flex;
  flex-direction: column;
  gap: 0.85rem;
  align-items: center;
}
.result-award-item {
  display: flex;
  align-items: center;
  gap: 0.65rem;
  font-family: var(--font-serif);
  font-size: 0.88rem;
  color: rgba(255,255,255,0.7);
}
.result-award-star {
  color: rgba(255, 200, 70, 0.9);
  font-size: 0.75rem;
  flex-shrink: 0;
}

/* Runner-up card */
.runner-up-card {
  display: flex;
  align-items: center;
  gap: 1rem;
  background: rgba(255,255,255,0.05);
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 12px;
  padding: 1rem 1.5rem;
  text-align: left;
}

.runner-up-color {
  width: 44px;
  height: 44px;
  border-radius: 8px;
  flex-shrink: 0;
}

.runner-up-title {
  font-size: 1rem;
  font-weight: 700;
  color: rgba(255,255,255,0.8);
}

.runner-up-meta {
  font-size: 0.75rem;
  color: rgba(255,255,255,0.35);
  margin-top: 0.2rem;
}

/* Battle timeline */
.battle-timeline {
  display: flex;
  flex-direction: column;
  gap: 0.4rem;
}

.battle-round {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  font-size: 0.8rem;
  color: rgba(255,255,255,0.45);
}

.battle-round-num {
  width: 1.6rem;
  text-align: center;
  color: rgba(255,255,255,0.2);
  font-size: 0.7rem;
  flex-shrink: 0;
}

.battle-winner-name {
  color: var(--winner-color, #e94560);
  font-weight: 700;
}

.battle-vs {
  color: rgba(255,255,255,0.2);
  font-size: 0.65rem;
}

/* Scroll hint */
.scroll-hint {
  position: relative;
  z-index: 2;
  margin-top: 2rem;
  color: rgba(255,255,255,0.25);
  font-size: 0.72rem;
  letter-spacing: 0.15em;
  animation: scrollBounce 2s ease-in-out infinite;
}

@keyframes scrollBounce {
  0%, 100% { transform: translateY(0); opacity: 0.25; }
  50%       { transform: translateY(4px); opacity: 0.5; }
}

.result-eyebrow {
  font-size: 0.75rem;
  letter-spacing: 0.4em;
  color: rgba(255,255,255,0.45);
  text-transform: uppercase;
  margin-bottom: 0.75rem;
}

.result-label {
  font-size: clamp(0.9rem, 2.5vw, 1.1rem);
  color: rgba(255,255,255,0.6);
  font-family: var(--font-serif);
  margin-bottom: 1rem;
}

.result-title {
  font-size: clamp(2.8rem, 9vw, 6.5rem);
  font-weight: 900;
  line-height: 1.1;
  letter-spacing: 0.05em;
  margin-bottom: 0.6rem;
  background: linear-gradient(135deg, #fff 30%, var(--winner-color, #e94560) 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.result-album {
  font-size: 0.85rem;
  color: rgba(255,255,255,0.35);
  letter-spacing: 0.1em;
  margin-bottom: 2.5rem;
}

.result-divider {
  width: 60px;
  height: 2px;
  background: var(--winner-color, #e94560);
  margin: 0 auto 2.5rem;
  border-radius: 2px;
  opacity: 0.7;
}

.result-lyrics {
  border-left: 3px solid var(--winner-color, #e94560);
  padding-left: 1.5rem;
  text-align: left;
  margin: 0 auto 2rem;
  max-width: 500px;
  min-height: 4.5rem;
}

.result-lyrics-text {
  font-family: var(--font-serif);
  font-size: clamp(0.95rem, 2.5vw, 1.15rem);
  line-height: 2;
  color: rgba(255,255,255,0.82);
  white-space: pre-line;
}

.result-story {
  font-size: 0.875rem;
  color: rgba(255,255,255,0.45);
  line-height: 1.8;
  max-width: 520px;
  margin: 0 auto 2.5rem;
  opacity: 0;
  transition: opacity 1s ease;
  font-family: var(--font-serif);
}

.result-story.visible { opacity: 1; }

.result-wins {
  display: inline-block;
  background: rgba(255,255,255,0.08);
  border: 1px solid rgba(255,255,255,0.15);
  border-radius: 50px;
  padding: 0.4rem 1.2rem;
  font-size: 0.78rem;
  letter-spacing: 0.1em;
  color: rgba(255,255,255,0.5);
  margin-bottom: 2.5rem;
}

.result-wins span {
  color: var(--winner-color, #e94560);
  font-weight: 700;
}

.result-btn {
  padding: 0.9rem 2.5rem;
  font-size: 0.95rem;
  font-family: var(--font-sans);
  font-weight: 700;
  letter-spacing: 0.12em;
  background: rgba(255,255,255,0.1);
  border: 1.5px solid rgba(255,255,255,0.4);
  color: #fff;
  border-radius: 50px;
  cursor: pointer;
  transition: all 0.3s ease;
  backdrop-filter: blur(4px);
}

.result-btn:hover {
  background: rgba(255,255,255,0.18);
  border-color: rgba(255,255,255,0.7);
  transform: translateY(-2px);
  box-shadow: 0 8px 30px rgba(0,0,0,0.3);
}

/* ===== RESULT STATS ===== */
.result-stats-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 0.75rem;
  max-width: 480px;
  margin: 0 auto 2rem;
}
.stat-cell {
  background: rgba(255,255,255,0.06);
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 10px;
  padding: 0.9rem 0.5rem;
  text-align: center;
}
.stat-value {
  font-size: 1.6rem;
  font-weight: 900;
  color: var(--winner-color, #e94560);
  line-height: 1;
}
.stat-label {
  font-size: 0.68rem;
  color: rgba(255,255,255,0.35);
  letter-spacing: 0.08em;
  margin-top: 0.3rem;
}
.same-album-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
  justify-content: center;
}
.same-album-chip {
  padding: 0.35rem 0.9rem;
  border-radius: 50px;
  border: 1px solid rgba(255,255,255,0.15);
  font-size: 0.8rem;
  color: rgba(255,255,255,0.6);
  background: rgba(255,255,255,0.05);
}


/* ===== LOADING SCREEN ===== */
.loading-screen {
  width: 100%; height: 100%;
  position: relative;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 2rem;
}

.loading-bg {
  position: absolute;
  inset: -10%;
  background-size: cover;
  background-position: center;
  filter: blur(28px) brightness(0.25) saturate(1.8);
  animation: kenBurns 20s ease-in-out infinite alternate;
}

.loading-cover {
  width: 140px;
  height: 140px;
  border-radius: 16px;
  object-fit: cover;
  position: relative;
  z-index: 1;
  box-shadow: 0 20px 60px rgba(0,0,0,0.7);
  animation: loadingPulse 2s ease-in-out infinite;
}

@keyframes loadingPulse {
  0%, 100% { transform: scale(1);    box-shadow: 0 20px 60px rgba(0,0,0,0.7); }
  50%       { transform: scale(1.04); box-shadow: 0 28px 80px rgba(0,0,0,0.8); }
}

.loading-title {
  font-size: clamp(1.6rem, 5vw, 2.8rem);
  font-weight: 900;
  color: #fff;
  position: relative;
  z-index: 1;
  text-align: center;
  letter-spacing: 0.05em;
}

.loading-label {
  font-size: 0.8rem;
  letter-spacing: 0.3em;
  color: rgba(255,255,255,0.4);
  text-transform: uppercase;
  position: relative;
  z-index: 1;
  text-align: center;
  animation: loadingDots 1.4s ease-in-out infinite;
}

@keyframes loadingDots {
  0%,100% { opacity: 0.4; }
  50%      { opacity: 0.9; }
}

.loading-dots {
  display: inline-flex;
  gap: 5px;
  margin-left: 4px;
}

.loading-dot {
  width: 4px;
  height: 4px;
  border-radius: 50%;
  background: rgba(255,255,255,0.5);
  animation: dotBounce 1.2s ease-in-out infinite;
}
.loading-dot:nth-child(2) { animation-delay: 0.2s; }
.loading-dot:nth-child(3) { animation-delay: 0.4s; }

@keyframes dotBounce {
  0%,80%,100% { transform: translateY(0);    opacity: 0.4; }
  40%          { transform: translateY(-6px); opacity: 1; }
}

/* ===== SCREEN TRANSITION ===== */
.screen-fade-enter {
  animation: screenFadeIn 0.6s ease both;
}

@keyframes screenFadeIn {
  from { opacity: 0; }
  to   { opacity: 1; }
}

/* ===== RESPONSIVE ===== */
@media (max-width: 600px) {
  .card-inner { padding: 1.5rem 1.25rem; max-width: 200px; }
  .card-album-thumb { width: 72px; height: 72px; margin-bottom: 1rem; }
  .card-title { font-size: 1.2rem; }
  .card-album { font-size: 0.72rem; }
  .pick-btn { padding: 0.55rem 1.4rem; font-size: 0.82rem; }
  .card-inner { max-width: none; }
  .result-lyrics { margin: 0 1rem 1.5rem; }
}

@media (hover: none) {
  /* Remove hover expand on touch devices */
  .game-screen.hover-left .bg-left,
  .game-screen.hover-left .bg-right,
  .game-screen.hover-right .bg-right,
  .game-screen.hover-right .bg-left { clip-path: unset; filter: blur(10px) brightness(0.5); }
  .game-screen.hover-left .bg-left  { clip-path: polygon(0 0, 50% 0, 50% 100%, 0 100%); }
  .game-screen.hover-left .bg-right { clip-path: polygon(50% 0, 100% 0, 100% 100%, 50% 100%); }
  .game-screen.hover-right .bg-right { clip-path: polygon(50% 0, 100% 0, 100% 100%, 50% 100%); }
  .game-screen.hover-right .bg-left  { clip-path: polygon(0 0, 50% 0, 50% 100%, 0 100%); }
  .game-screen.hover-left .seam,
  .game-screen.hover-right .seam { left: 50%; }
  .game-screen.hover-left .song-card,
  .game-screen.hover-right .song-card { flex: 1; }
}
</style>
</head>
