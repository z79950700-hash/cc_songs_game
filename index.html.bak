// ===== GAME STATE =====
const state = {
  phase: 'intro',
  round: 0,
  pool: [],
  left: null,
  right: null,
  wins: {},
  history: [],
  winner: null
};

// ===== UTILITIES =====
function shuffle(arr) {
  const a = [...arr];
  for (let i = a.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [a[i], a[j]] = [a[j], a[i]];
  }
  return a;
}

function songWithMaxWins() {
  let maxWins = 0;
  let winner = null;
  // Default: whichever song won the last round
  const lastWinner = state.history[state.history.length - 1]?.winner;
  for (const [id, w] of Object.entries(state.wins)) {
    if (w > maxWins) {
      maxWins = w;
      winner = SONGS.find(s => s.id === parseInt(id));
    } else if (w === maxWins && lastWinner && parseInt(id) === lastWinner.id) {
      winner = lastWinner;
    }
  }
  return { song: winner, wins: maxWins };
}

function proxyUrl(url) {
  if (!url) return '';
  return 'https://images.weserv.nl/?url=' + url.replace(/^https?:\/\//, '') + '&w=600&h=600&fit=cover&we';
}

function adjustColor(hex, amt) {
  if (!hex || hex[0] !== '#') return hex || '#333';
  const clamp = v => Math.max(0, Math.min(255, v));
  const r = clamp(parseInt(hex.slice(1,3), 16) + amt);
  const g = clamp(parseInt(hex.slice(3,5), 16) + amt);
  const b = clamp(parseInt(hex.slice(5,7), 16) + amt);
  return `rgb(${r},${g},${b})`;
}

// Extract dominant (saturated, mid-brightness) color from image via canvas
function extractDominantColor(proxyImgUrl) {
  return new Promise(resolve => {
    if (!proxyImgUrl) return resolve(null);
    const img = new Image();
    img.crossOrigin = 'anonymous';
    img.onload = () => {
      try {
        const c = document.createElement('canvas');
        c.width = c.height = 80;
        const ctx = c.getContext('2d');
        ctx.drawImage(img, 0, 0, 80, 80);
        const d = ctx.getImageData(0, 0, 80, 80).data;
        let r = 0, g = 0, b = 0, n = 0;
        for (let i = 0; i < d.length; i += 4) {
          const lum = (d[i] + d[i+1] + d[i+2]) / 3;
          const sat = Math.max(d[i], d[i+1], d[i+2]) - Math.min(d[i], d[i+1], d[i+2]);
          if (lum > 25 && lum < 230 && sat > 20) {
            r += d[i]; g += d[i+1]; b += d[i+2]; n++;
          }
        }
        if (n === 0) return resolve(null);
        const toH = v => Math.round(v/n).toString(16).padStart(2,'0');
        resolve('#' + toH(r) + toH(g) + toH(b));
      } catch(e) { resolve(null); }
    };
    img.onerror = () => resolve(null);
    img.src = proxyImgUrl;
  });
}

function setSongBackground(el, song) {
  const base = song.dominantColor || song.color;
  const fallback = `radial-gradient(ellipse at 60% 40%, ${base}dd 0%, ${base}44 50%, #000 100%)`;
  el.style.backgroundImage = fallback;
  const purl = song.coverUrl ? proxyUrl(song.coverUrl) : '';
  if (!purl) return;
  const img = new Image();
  img.onload = () => { el.style.backgroundImage = `url(${purl})`; };
  img.src = purl;
}

function typewriterReveal(el, text, delayMs = 800) {
  el.textContent = '';
  const chars = [...text];
  let i = 0;
  setTimeout(() => {
    const timer = setInterval(() => {
      el.textContent += chars[i++];
      if (i >= chars.length) clearInterval(timer);
    }, 55);
  }, delayMs);
}

// ===== INIT GAME =====
function initGame() {
  const shuffled = shuffle(SONGS);
  state.round = 0;
  state.wins = {};
  state.history = [];
  state.winner = null;
  state.left = shuffled[0];
  state.right = shuffled[1];
  state.pool = shuffled.slice(2);
  state.phase = 'playing';
  renderGame();
}

// ===== ON PICK =====
function onPick(side) {
  if (state.phase !== 'playing') return;  // block double-clicks / re-entry

  const winner = state[side];
  const loser = state[side === 'left' ? 'right' : 'left'];

  state.wins[winner.id] = (state.wins[winner.id] || 0) + 1;
  state.history.push({ winner, loser });
  state.round++;

  const winnerCard = document.querySelector(`.card-${side}`);
  const loserCard = document.querySelector(`.card-${side === 'left' ? 'right' : 'left'}`);
  const screen = document.querySelector('.game-screen');

  // Remove hover state
  screen.classList.remove('hover-left', 'hover-right');

  if (state.round >= 15) {
    // Final round — show loading screen, fetch audio in parallel, then result
    state.phase = 'transitioning';  // immediately block any further picks
    if (winnerCard) winnerCard.classList.add('card-winning');
    if (loserCard) loserCard.classList.add('card-exiting');

    state.winner = winner;
    state.winnerWins = state.wins[winner.id] || 1;

    // Start audio fetch immediately (runs while animation plays)
    const audioFetch = fetchSongAudio(winner);

    setTimeout(() => {
      state.phase = 'loading';
      renderLoading(winner);

      // Wait for audio (max 8s timeout so page never hangs)
      const timeout = new Promise(resolve => setTimeout(resolve, 8000));
      Promise.race([audioFetch, timeout]).then(audioUrl => {
        state._preloadedAudioUrl = (typeof audioUrl === 'string') ? audioUrl : null;
        state.phase = 'result';
        renderResult();
      });
    }, 500);
    return;
  }

  // Animate exit/win
  if (winnerCard) winnerCard.classList.add('card-winning');
  if (loserCard) loserCard.classList.add('card-exiting');

  setTimeout(() => {
    // Replace loser
    const replacement = state.pool.pop();
    state[side === 'left' ? 'right' : 'left'] = replacement;
    // Update pool if it runs low (wrap around already-shown songs)
    if (state.pool.length === 0) {
      const usedIds = new Set([state.left?.id, state.right?.id]);
      state.history.forEach(h => { usedIds.add(h.winner.id); usedIds.add(h.loser.id); });
      state.pool = shuffle(SONGS.filter(s => !usedIds.has(s.id)));
      if (state.pool.length === 0) {
        state.pool = shuffle(SONGS.filter(s => s.id !== state.left?.id && s.id !== state.right?.id));
      }
    }
    renderGame();
  }, 280);
}

// ===== PREFETCH ALBUM ART + DOMINANT COLOR =====
async function prefetchAlbumArt() {
  const seen = new Set();
  const uniqueAlbums = SONGS.filter(s => {
    if (seen.has(s.album)) return false;
    seen.add(s.album); return true;
  });

  await Promise.allSettled(uniqueAlbums.map(async (ref) => {
    try {
      // Try album search first, then artist-only search as fallback
      const queries = [
        `五月天 ${ref.album}`,
        `Mayday ${ref.album}`,
        '五月天'
      ];
      let art = null;
      for (const q of queries) {
        const resp = await fetch(
          `https://itunes.apple.com/search?term=${encodeURIComponent(q)}&entity=album&limit=8&media=music&country=tw`,
          { signal: AbortSignal.timeout(8000) }
        );
        const data = await resp.json();
        if (!data.results?.length) continue;
        const best = data.results.sort((a, b) => {
          const ya = Math.abs(parseInt(a.releaseDate || '0') - ref.year);
          const yb = Math.abs(parseInt(b.releaseDate || '0') - ref.year);
          return ya - yb;
        })[0];
        art = best.artworkUrl100.replace('100x100bb', '600x600bb');
        break;
      }
      if (!art) return;
      const affected = SONGS.filter(s => s.album === ref.album);
      affected.forEach(s => s.coverUrl = art);
      // Extract dominant color via canvas (weserv proxy adds CORS headers)
      const purl = proxyUrl(art);
      const dominant = await extractDominantColor(purl);
      if (dominant) affected.forEach(s => s.dominantColor = dominant);
    } catch(e) { /* keep gradient fallback */ }
  }));
}

// ===== RENDER INTRO =====
function renderIntro() {
  const app = document.getElementById('app');
  app.innerHTML = '';

  const screen = document.createElement('div');
  screen.className = 'intro-screen screen-fade-enter';

  // Particles — mix of white and warm orange tones
  const particleContainer = document.createElement('div');
  particleContainer.className = 'intro-particles';
  for (let i = 0; i < 55; i++) {
    const p = document.createElement('div');
    p.className = 'particle';
    const left = Math.random() * 100;
    const dur = 8 + Math.random() * 14;
    const delay = Math.random() * 12;
    const size = 1 + Math.random() * 2.5;
    const drift = (Math.random() - 0.5) * 80;
    const warm = Math.random() < 0.3;
    const color = warm
      ? `rgba(255,${130 + Math.floor(Math.random() * 80)},40,0.75)`
      : `rgba(255,255,255,${0.4 + Math.random() * 0.4})`;
    p.style.cssText = `left:${left}%;bottom:-5px;width:${size}px;height:${size}px;animation-duration:${dur}s;animation-delay:-${delay}s;--drift:${drift}px;background:${color}`;
    particleContainer.appendChild(p);
  }

  screen.innerHTML = `
    <div class="intro-meta">
      <span>1999</span>
      <span class="intro-meta-dot">✦</span>
      <span>MAYDAY 五月天</span>
      <span class="intro-meta-dot">✦</span>
      <span>26年</span>
    </div>

    <div class="intro-mascot">
      <div class="intro-mascot-glow"></div>
      <!-- 魔法胡萝卜 -->
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 80 118" width="90" height="118">
        <!-- Leaves -->
        <path d="M40 30 C33 21 17 17 15 25 C24 23 33 26 40 30Z" fill="#52b04a"/>
        <path d="M40 28 C37 15 35 4 37 0 C38 9 39 19 40 28Z" fill="#48a040"/>
        <path d="M40 26 C40 11 40 1 40 0 C40 1 40 11 40 26Z" fill="#5cc054" stroke="#48a040" stroke-width="0.8"/>
        <path d="M40 28 C43 15 45 4 43 0 C42 9 41 19 40 28Z" fill="#48a040"/>
        <path d="M40 30 C47 21 63 17 65 25 C56 23 47 26 40 30Z" fill="#52b04a"/>
        <!-- Carrot body -->
        <path d="M31 30 Q23 58 26 80 Q32 102 40 115 Q48 102 54 80 Q57 58 49 30 Z" fill="#ff7800"/>
        <!-- Highlight stripe -->
        <path d="M35 35 Q33 60 35 78" stroke="rgba(255,210,110,0.35)" stroke-width="3.5" fill="none" stroke-linecap="round"/>
        <!-- Texture lines -->
        <path d="M34 47 Q40 45 46 47" stroke="#d96200" stroke-width="1.5" fill="none" stroke-linecap="round"/>
        <path d="M32 62 Q40 60 48 62" stroke="#d96200" stroke-width="1.5" fill="none" stroke-linecap="round"/>
        <path d="M33 77 Q40 75 47 77" stroke="#d96200" stroke-width="1.5" fill="none" stroke-linecap="round"/>
        <!-- Sparkle left -->
        <g transform="translate(8,42) scale(0.9)">
          <line x1="0" y1="-7" x2="0" y2="7" stroke="#ffd060" stroke-width="1.5" stroke-linecap="round"/>
          <line x1="-7" y1="0" x2="7" y2="0" stroke="#ffd060" stroke-width="1.5" stroke-linecap="round"/>
          <line x1="-5" y1="-5" x2="5" y2="5" stroke="#ffd060" stroke-width="0.8" stroke-linecap="round"/>
          <line x1="5" y1="-5" x2="-5" y2="5" stroke="#ffd060" stroke-width="0.8" stroke-linecap="round"/>
        </g>
        <!-- Sparkle right small -->
        <g transform="translate(66,35) scale(0.6)">
          <line x1="0" y1="-7" x2="0" y2="7" stroke="#ffd060" stroke-width="1.5" stroke-linecap="round"/>
          <line x1="-7" y1="0" x2="7" y2="0" stroke="#ffd060" stroke-width="1.5" stroke-linecap="round"/>
          <line x1="-5" y1="-5" x2="5" y2="5" stroke="#ffd060" stroke-width="0.8" stroke-linecap="round"/>
          <line x1="5" y1="-5" x2="-5" y2="5" stroke="#ffd060" stroke-width="0.8" stroke-linecap="round"/>
        </g>
        <!-- Dot accent -->
        <circle cx="18" cy="62" r="2" fill="#ffd060" opacity="0.7"/>
        <circle cx="64" cy="58" r="1.5" fill="#ffd060" opacity="0.6"/>
      </svg>
    </div>

    <div class="intro-title">你心中<br>那首歌</div>
    <div class="intro-subtitle">五月天唱了 26 年的故事里<br>有一首，是为你而生的</div>
    <button class="intro-btn" id="startBtn" disabled style="opacity:0.5;cursor:default">专辑封面加载中…</button>
    <div class="intro-rules">Top 50 热门歌曲 · 15 轮直觉对决 · 每次答案都是真实的你</div>
  `;
  screen.insertBefore(particleContainer, screen.firstChild);
  app.appendChild(screen);

  prefetchAlbumArt().then(() => {
    const btn = document.getElementById('startBtn');
    if (btn) {
      btn.disabled = false;
      btn.style.opacity = '';
      btn.style.cursor = '';
      btn.textContent = '开始寻找 →';
      btn.addEventListener('click', initGame);
    }
  });
}

// ===== RENDER GAME =====
function renderGame() {
  const app = document.getElementById('app');
  const isFirstRender = !document.querySelector('.game-screen');

  if (isFirstRender) {
    app.innerHTML = '';
  }

  const leftSong = state.left;
  const rightSong = state.right;

  if (isFirstRender) {
    const screen = document.createElement('div');
    screen.className = 'game-screen screen-fade-enter';
    screen.id = 'gameScreen';

    screen.innerHTML = `
      <div class="bg-layer bg-left" id="bgLeft"></div>
      <div class="bg-layer bg-right" id="bgRight"></div>
      <div class="seam"></div>
      <div class="round-counter">
        <div class="round-text">第 <span id="roundNum">1</span> / 15 轮</div>
        <div class="round-bar"><div class="round-fill" id="roundFill" style="width:0%"></div></div>
      </div>
      <div class="vs-badge">VS</div>
      <div class="cards-container" id="cardsContainer">
        <div class="song-card card-left" id="cardLeft"></div>
        <div class="song-card card-right" id="cardRight"></div>
      </div>
    `;

    app.appendChild(screen);

    // Hover listeners
    const cardLeft = screen.querySelector('#cardLeft');
    const cardRight = screen.querySelector('#cardRight');

    cardLeft.addEventListener('mouseenter', () => screen.classList.add('hover-left'));
    cardLeft.addEventListener('mouseleave', () => screen.classList.remove('hover-left'));
    cardRight.addEventListener('mouseenter', () => screen.classList.add('hover-right'));
    cardRight.addEventListener('mouseleave', () => screen.classList.remove('hover-right'));
  }

  // Update dynamic content
  const screen = document.getElementById('gameScreen');
  document.getElementById('roundNum').textContent = state.round + 1;
  document.getElementById('roundFill').style.width = `${(state.round / 15) * 100}%`;

  const bgLeft = document.getElementById('bgLeft');
  const bgRight = document.getElementById('bgRight');
  const lc = leftSong.dominantColor  || leftSong.color;
  const rc = rightSong.dominantColor || rightSong.color;
  bgLeft.style.background  = `radial-gradient(ellipse at 35% 50%, ${adjustColor(lc,  60)} 0%, ${lc}  45%, ${adjustColor(lc,  -60)} 100%)`;
  bgRight.style.background = `radial-gradient(ellipse at 65% 50%, ${adjustColor(rc, 60)} 0%, ${rc} 45%, ${adjustColor(rc, -60)} 100%)`;
  bgLeft.style.opacity  = '';
  bgRight.style.opacity = '';

  // Update CSS vars for button colors
  screen.style.setProperty('--color-left', leftSong.color);
  screen.style.setProperty('--color-right', rightSong.color);

  // Render cards
  buildCard(document.getElementById('cardLeft'), leftSong, 'left');
  buildCard(document.getElementById('cardRight'), rightSong, 'right');

  // Trigger enter animation on cards after update
  const cards = screen.querySelectorAll('.song-card');
  cards.forEach(c => {
    c.classList.remove('card-exiting', 'card-winning', 'card-entering');
    void c.offsetWidth; // reflow
    c.classList.add('card-entering');
    setTimeout(() => c.classList.remove('card-entering'), 400);
  });
}

function buildCard(cardEl, song, side) {
  const purl = song.coverUrl ? proxyUrl(song.coverUrl) : '';
  const base = song.dominantColor || song.color;
  const fallbackStyle = `background:linear-gradient(145deg,${adjustColor(base,60)} 0%,${base} 55%,${adjustColor(base,-50)} 100%)`;
  const imgTag = purl
    ? `<img class="card-album-thumb" src="${purl}" alt="${song.album}" crossorigin="anonymous"
           onerror="this.style.cssText='${fallbackStyle};width:220px;height:220px;border-radius:14px;display:block;margin:0 auto 1.5rem';this.removeAttribute('src')">`
    : `<div class="card-album-thumb" style="${fallbackStyle}"></div>`;

  cardEl.innerHTML = `
    <div class="card-inner">
      ${imgTag}
      <div class="card-title">${song.title}</div>
      <div class="card-album">${song.album} · ${song.year}</div>
      <button class="pick-btn" data-side="${side}">选择这首 ♡</button>
    </div>
  `;
  cardEl.querySelector('.pick-btn').addEventListener('click', (e) => {
    e.stopPropagation();
    onPick(side);
  });
  cardEl.addEventListener('click', () => onPick(side));
}

// ===== LOADING SCREEN =====
function renderLoading(song) {
  const app = document.getElementById('app');
  app.innerHTML = '';

  const screen = document.createElement('div');
  screen.className = 'loading-screen screen-fade-enter';

  const base = song.dominantColor || song.color;
  const coverSrc = song.coverUrl ? proxyUrl(song.coverUrl) : '';

  screen.innerHTML = `
    <div class="loading-bg" id="loadingBg"></div>
    <img class="loading-cover" id="loadingCover"
      src="${coverSrc}"
      onerror="this.style.cssText='background:linear-gradient(145deg,${adjustColor(base,60)} 0%,${base} 55%,${adjustColor(base,-50)} 100%);width:140px;height:140px;border-radius:16px;position:relative;z-index:1;animation:loadingPulse 2s ease-in-out infinite'"
      alt="${song.title}">
    <div class="loading-title" style="color:#fff">${song.title}</div>
    <div class="loading-label">正在加载结果
      <span class="loading-dots">
        <span class="loading-dot"></span>
        <span class="loading-dot"></span>
        <span class="loading-dot"></span>
      </span>
    </div>
  `;

  app.appendChild(screen);
  setSongBackground(document.getElementById('loadingBg'), song);
}

// ===== FETCH SONG AUDIO =====
async function fetchSongAudio(song) {
  // 1. 网易云完整歌曲（via allorigins CORS proxy）
  try {
    const searchUrl = 'https://music.163.com/api/search/get?s='
      + encodeURIComponent('五月天 ' + song.title)
      + '&type=1&offset=0&total=true&limit=5';
    const res = await fetch(
      'https://api.allorigins.win/raw?url=' + encodeURIComponent(searchUrl),
      { signal: AbortSignal.timeout(6000) }
    );
    const data = await res.json();
    const id = data?.result?.songs?.[0]?.id;
    if (id) return `https://music.163.com/song/media/outer/url?id=${id}`;
  } catch(e) {}

  // 2. iTunes 30s preview 兜底
  try {
    const q = encodeURIComponent('五月天 ' + song.title);
    const res = await fetch(
      `https://itunes.apple.com/search?term=${q}&entity=song&limit=10&media=music&country=tw`,
      { signal: AbortSignal.timeout(8000) }
    );
    const data = await res.json();
    const match = data.results?.find(r =>
      r.previewUrl && (r.artistName.includes('五月天') || r.artistName.toLowerCase().includes('mayday'))
    ) || data.results?.find(r => r.previewUrl);
    if (match?.previewUrl) return match.previewUrl;
  } catch(e) {}

  return null;
}

// ===== RENDER RESULT =====
function renderResult() {
  const app = document.getElementById('app');
  app.innerHTML = '';

  const song = state.winner;
  const wins = state.winnerWins;
  const totalYears = new Date().getFullYear() - song.year;

  // Defeated songs (rounds where winner won)
  const defeatedSongs = state.history
    .filter(h => h.winner.id === song.id)
    .map(h => h.loser);

  // First win round
  const firstWinRound = state.history.findIndex(h => h.winner.id === song.id) + 1;

  // Same album songs (excluding winner)
  const sameAlbum = SONGS.filter(s => s.album === song.album && s.id !== song.id).slice(0, 5);

  const screen = document.createElement('div');
  screen.className = 'result-screen screen-fade-enter';
  screen.style.setProperty('--winner-color', song.dominantColor || song.color);

  screen.innerHTML = `
    <div class="result-bg" id="resultBg"></div>
    <div class="result-bg-overlay"></div>
    <div class="result-scroll">

    <!-- ① 主标题 -->
    <div class="result-content">
      <div class="result-eyebrow">15 轮直觉对决</div>
      <div class="result-label">你最爱的五月天歌曲是</div>
      <div class="result-title">${song.title}</div>
      <div class="result-album">${song.album} &nbsp;·&nbsp; ${song.year}</div>
      <div class="result-divider"></div>

      <!-- 歌词 -->
      <div class="result-lyrics">
        <div class="result-lyrics-text" id="lyricsText"></div>
      </div>

      <!-- 创作背景 -->
      <div class="result-story" id="storyText">${song.backgroundStory}</div>
    </div>

    <div class="scroll-hint">↓ 向下滑动 ↓</div>

    <!-- ② 数据面板 -->
    <div class="result-section-divider"></div>
    <div class="result-section">
      <div class="result-section-title">这首歌与你</div>
      <div class="result-stats-grid">
        <div class="stat-cell">
          <div class="stat-value">${wins}</div>
          <div class="stat-label">轮对决胜出</div>
        </div>
        <div class="stat-cell">
          <div class="stat-value">第 ${firstWinRound}</div>
          <div class="stat-label">轮首次选择</div>
        </div>
        <div class="stat-cell">
          <div class="stat-value">${totalYears}</div>
          <div class="stat-label">年前发行</div>
        </div>
      </div>
    </div>

    <!-- ③ 奖项认可 -->
    ${(AWARDS[song.id] || []).length ? `
    <div class="result-section-divider"></div>
    <div class="result-section">
      <div class="result-section-title">奖项与认可</div>
      <div class="result-awards-list">
        ${(AWARDS[song.id] || []).map(a => `
          <div class="result-award-item">
            <span class="result-award-star">★</span>
            <span>${a}</span>
          </div>
        `).join('')}
      </div>
    </div>` : ''}

    <!-- ④ 关于这首歌 -->
    <div class="result-section-divider"></div>
    <div class="result-section" style="text-align:left">
      <div class="result-section-title" style="text-align:center">为什么是这首</div>
      <div style="font-family:var(--font-serif);font-size:.9rem;color:rgba(255,255,255,.55);line-height:2">
        <p style="margin-bottom:1rem">
          在所有五月天的歌曲里，你的直觉选择了《<em style="color:rgba(255,255,255,.8)">${song.title}</em>》。
          它发行于 ${song.year} 年，收录在专辑《${song.album}》中，距今已陪伴歌迷走过 ${totalYears} 年。
        </p>
        <p style="margin-bottom:1rem">
          ${song.backgroundStory}
        </p>
        <p style="color:rgba(255,255,255,.35);font-style:italic;font-size:.82rem">
          「直觉是最诚实的答案。在 15 次选择里，你总是回到这里。」
        </p>
      </div>
    </div>

    <!-- ④ 你击败了谁 -->
    ${defeatedSongs.length ? `
    <div class="result-section-divider"></div>
    <div class="result-section">
      <div class="result-section-title">一路击败的对手</div>
      <div class="defeated-chips">
        ${defeatedSongs.map(s => `<span class="defeated-chip">${s.title}</span>`).join('')}
      </div>
    </div>` : ''}

    <!-- ⑤ 同专辑推荐 -->
    ${sameAlbum.length ? `
    <div class="result-section-divider"></div>
    <div class="result-section">
      <div class="result-section-title">同专辑 · 你可能也爱</div>
      <div class="same-album-chips">
        ${sameAlbum.map(s => `<span class="same-album-chip">${s.title}</span>`).join('')}
      </div>
    </div>` : ''}

    <!-- ⑥ 对决回顾 -->
    <div class="result-section-divider"></div>
    <div class="result-section">
      <div class="result-section-title">15 轮对决回顾</div>
      <div class="battle-timeline" id="battleTimeline"></div>
    </div>

    <!-- ⑦ 再来一次 -->
    <div class="result-section-divider"></div>
    <div class="result-section" style="text-align:center;padding-bottom:2rem">
      <div style="font-family:var(--font-serif);font-size:.85rem;color:rgba(255,255,255,.3);margin-bottom:1.5rem">
        每一次游戏，答案都可能不同——那才是真实的你
      </div>
      <button class="result-btn" id="restartBtn">再玩一次</button>
    </div>

    </div><!-- /.result-scroll -->
  `;

  app.appendChild(screen);

  setSongBackground(document.getElementById('resultBg'), song);

  setTimeout(() => {
    typewriterReveal(document.getElementById('lyricsText'), song.lyricsExcerpt, 0);
  }, 600);

  setTimeout(() => {
    const el = document.getElementById('storyText');
    if (el) el.classList.add('visible');
  }, 2200);

  // Battle timeline
  const timeline = document.getElementById('battleTimeline');
  if (timeline) {
    state.history.forEach((h, i) => {
      const isWin = h.winner.id === song.id;
      const row = document.createElement('div');
      row.className = 'battle-round';
      row.innerHTML = `
        <span class="battle-round-num">R${i+1}</span>
        <span class="${isWin ? 'battle-winner-name' : ''}" style="${!isWin ? 'color:rgba(255,255,255,.3)' : ''}">${h.winner.title}</span>
        <span class="battle-vs">›</span>
        <span style="color:rgba(255,255,255,.25);text-decoration:line-through">${h.loser.title}</span>
      `;
      timeline.appendChild(row);
    });
  }

  document.getElementById('restartBtn').addEventListener('click', () => {
    if (state._bgAudio) { state._bgAudio.pause(); state._bgAudio = null; }
    renderIntro();
  });

  // Background audio — no UI, just play silently
  const audioUrl = state._preloadedAudioUrl || null;
  state._preloadedAudioUrl = null;
  if (audioUrl) {
    const isPreview = audioUrl.includes('itunes.apple.com') || audioUrl.includes('mzstatic.com');
    const audio = new Audio(audioUrl);
    audio.loop = isPreview;
    audio.volume = 0.4;
    audio.play().catch(() => {});
    state._bgAudio = audio;
  }
}

// ===== BOOT =====
renderIntro();
</script>
</body>
</html>
